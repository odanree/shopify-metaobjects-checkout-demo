{% comment %}
  Lookbook Section — renders entries from the "lookbook" metaobject type.
  Each entry has: title, hero_image, description, products (list.product_reference).
  Editors can add up to 4 featured lookbook entries via the customizer.
{% endcomment %}

{{ 'section-lookbook.css' | asset_url | stylesheet_tag }}

<section
  class="lookbook"
  id="shopify-section-{{ section.id }}"
  style="
    --lookbook-bg: {{ section.settings.background_color }};
    --lookbook-text: {{ section.settings.text_color }};
  "
>
  {%- if section.settings.heading != blank -%}
    <div class="lookbook__header">
      <h2 class="lookbook__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lookbook__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="lookbook__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'lookbook_entry' -%}
        {%- assign entry = block.settings.lookbook_entry -%}
        {%- if entry != blank -%}
          {%- render 'metaobject-lookbook', metaobject: entry, block: block -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .lookbook {
    background-color: var(--lookbook-bg, #f9f9f9);
    color: var(--lookbook-text, #1a1a1a);
    padding: 60px 20px;
  }
  .lookbook__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .lookbook__heading {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 8px;
  }
  .lookbook__subheading {
    font-size: 1rem;
    opacity: 0.7;
    margin: 0;
  }
  .lookbook__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .lookbook__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Lookbook",
  "tag": "section",
  "class": "section-lookbook",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Lookbook"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore curated collections and styles"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "lookbook_entry",
      "name": "Lookbook Entry",
      "limit": 4,
      "settings": [
        {
          "type": "metaobject",
          "id": "lookbook_entry",
          "label": "Lookbook entry",
          "metaobject_type": "lookbook"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        { "type": "lookbook_entry" },
        { "type": "lookbook_entry" }
      ]
    }
  ]
}
{% endschema %}
