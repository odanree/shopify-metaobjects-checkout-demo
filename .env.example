# Shopify app credentials (from Partners dashboard)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Loyalty points configuration
# How many points a customer earns per $1 spent (must match checkout extension setting)
LOYALTY_POINTS_PER_DOLLAR=10
# How many points = $1 in redemption value (e.g. 100 = 100pts per $1)
LOYALTY_REDEMPTION_RATE=100

# App server
PORT=3001
NODE_ENV=development
